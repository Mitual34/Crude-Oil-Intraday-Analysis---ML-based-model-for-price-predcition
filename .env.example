# Copy to ".env" and fill in to enable optional email / cloud features.
# These are read by the app from the environment; never commit real secrets.

# --- Email delivery (--email) ---
OIL_REPORT_SENDER_EMAIL=your_email@example.com
OIL_REPORT_SENDER_PASSWORD=your_app_password
OIL_REPORT_SMTP_SERVER=smtp.gmail.com
OIL_REPORT_SMTP_PORT=587

# --- Google Cloud Storage upload (--gcs-bucket) ---
GOOGLE_CLIENT_ID=your_google_client_id
